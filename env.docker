# Docker Compose Environment Variables

# PostgreSQL
POSTGRES_DB=ngx_blog
POSTGRES_USER=ngx_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_PORT=5432

# Application
APP_PORT=4000
JWT_SECRET=changeme_in_production
ALLOWED_ORIGINS=http://localhost:4000,http://localhost

# Redis (optional)
REDIS_PORT=6379
